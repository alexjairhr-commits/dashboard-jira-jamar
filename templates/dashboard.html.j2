{#- Dashboard Ejecutivo de Jira - Tema BLANCO, paleta Muebles Jamar. SSR. -#}
{%- set PALETTE = ['#E30613','#14213D','#F4A81D','#2E933C','#7A5AD8','#0EA5A4','#EF7C1B','#3B82F6','#D6336C','#8D6E63'] -%}

{%- macro bars(dist, limit=99) -%}
  {%- set mx = (dist.data | max) or 1 -%}
  {%- for i in range(dist.labels | length) -%}
    {%- if i < limit -%}
    <div class="bar-row">
      <span class="bar-label" title="{{ dist.labels[i] }}">{{ dist.labels[i] }}</span>
      <span class="bar-track"><span class="bar-fill" style="width: {{ (dist.data[i] / mx * 100) | round(1) }}%; background: {{ PALETTE[i % (PALETTE | length)] }};"></span></span>
      <span class="bar-val">{{ dist.data[i] }}</span>
    </div>
    {%- endif -%}
  {%- endfor -%}
{%- endmacro -%}

{%- macro trendchart(t) -%}
  {%- set mx = ((t.created + t.closed) | max) or 1 -%}
  <div class="trend">
    {%- for i in range(t.labels | length) -%}
    <div class="trend-col">
      <div class="trend-bars">
        <span class="tb created" style="height: {{ (t.created[i] / mx * 100) | round(1) }}%" title="Creadas: {{ t.created[i] }}"></span>
        <span class="tb closed" style="height: {{ (t.closed[i] / mx * 100) | round(1) }}%" title="Cerradas: {{ t.closed[i] }}"></span>
      </div>
      <span class="trend-x">{{ t.labels[i] }}</span>
    </div>
    {%- endfor -%}
  </div>
{%- endmacro -%}
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ metrics.meta.title }}</title>
  <style>
    :root {
      --bg: #ffffff; --panel: #ffffff; --panel-2: #f4f5f7; --text: #1f2733;
      --muted: #6b7280; --border: #e4e7ec;
      --jamar-red: #E30613; --jamar-red-dark: #b3050f; --jamar-navy: #14213D; --jamar-gold: #F4A81D;
      --green: #2E933C; --amber: #F4A81D; --red: #E30613; --blue: #14213D; --violet: #7A5AD8;
      --shadow: 0 2px 10px rgba(20,33,61,.08);
    }
    * { box-sizing: border-box; }
    body { margin: 0; font-family: 'Segoe UI', system-ui, -apple-system, Roboto, Arial, sans-serif; background: var(--bg); color: var(--text); line-height: 1.45; }
    header { background: linear-gradient(135deg, var(--jamar-red), var(--jamar-red-dark)); padding: 22px 28px; color: #fff; }
    header h1 { margin: 0; font-size: 1.5rem; letter-spacing: .2px; }
    header .sub { color: #ffe3e3; font-size: .85rem; margin-top: 4px; }
    .container { max-width: 1320px; margin: 0 auto; padding: 22px 20px 60px; }
    .filters { display: flex; flex-wrap: wrap; gap: 14px; align-items: end; background: var(--panel); border: 1px solid var(--border); border-radius: 14px; padding: 16px 18px; margin-bottom: 22px; box-shadow: var(--shadow); }
    .filters .field { display: flex; flex-direction: column; gap: 5px; }
    .filters label { font-size: .72rem; text-transform: uppercase; letter-spacing: .04em; color: var(--muted); font-weight: 600; }
    .filters select, .filters input { background: #fff; color: var(--text); border: 1px solid var(--border); border-radius: 8px; padding: 8px 10px; font-size: .9rem; min-width: 150px; }
    .filters button { background: var(--jamar-red); color: #fff; border: none; cursor: pointer; border-radius: 8px; padding: 9px 16px; font-size: .9rem; font-weight: 600; }
    .filters button:hover { background: var(--jamar-red-dark); }
    .filters button.ghost { background: #fff; border: 1px solid var(--border); color: var(--muted); }
    .js-only { display: none; }
    .kpis { display: grid; gap: 16px; margin-bottom: 24px; grid-template-columns: repeat(auto-fit, minmax(170px, 1fr)); }
    .kpi { background: var(--panel); border: 1px solid var(--border); border-top: 4px solid var(--jamar-navy); border-radius: 14px; padding: 16px 18px; box-shadow: var(--shadow); }
    .kpi .label { font-size: .76rem; color: var(--muted); text-transform: uppercase; letter-spacing: .03em; font-weight: 600; }
    .kpi .value { font-size: 2rem; font-weight: 700; margin-top: 6px; color: var(--jamar-navy); }
    .kpi .unit { font-size: .9rem; color: var(--muted); font-weight: 500; }
    .kpi.green { border-top-color: var(--green); } .kpi.amber { border-top-color: var(--amber); }
    .kpi.red { border-top-color: var(--jamar-red); } .kpi.navy { border-top-color: var(--jamar-navy); }
    .kpi.gold { border-top-color: var(--jamar-gold); } .kpi.violet { border-top-color: var(--violet); }
    .badge { display:inline-block; margin-top:8px; padding:2px 10px; border-radius:999px; font-size:.72rem; font-weight:700; }
    .badge.green { background: rgba(46,147,60,.12); color: var(--green); }
    .badge.amber { background: rgba(244,168,29,.15); color: #9a6a00; }
    .badge.red { background: rgba(227,6,19,.10); color: var(--jamar-red); }
    .grid { display: grid; gap: 18px; margin-bottom: 24px; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); }
    .card { background: var(--panel); border: 1px solid var(--border); border-radius: 14px; padding: 18px; box-shadow: var(--shadow); }
    .card h3 { margin: 0 0 14px; font-size: 1rem; color: var(--jamar-navy); }
    .card.wide { grid-column: 1 / -1; }
    .bars { display: flex; flex-direction: column; }
    .bar-row { display: grid; grid-template-columns: 130px 1fr 40px; gap: 10px; align-items: center; margin: 6px 0; font-size: .82rem; }
    .bar-label { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; color: var(--text); }
    .bar-track { background: var(--panel-2); border-radius: 6px; height: 18px; overflow: hidden; }
    .bar-fill { display:block; height: 100%; border-radius: 6px; min-width: 2px; transition: width .3s; }
    .bar-val { text-align: right; font-variant-numeric: tabular-nums; color: var(--muted); font-weight: 600; }
    .trend { display: flex; gap: 12px; align-items: flex-end; height: 220px; padding-top: 8px; overflow-x: auto; }
    .trend-col { display: flex; flex-direction: column; align-items: center; flex: 1 0 44px; height: 100%; }
    .trend-bars { display: flex; gap: 3px; align-items: flex-end; height: 100%; }
    .tb { width: 14px; border-radius: 4px 4px 0 0; min-height: 2px; }
    .tb.created { background: var(--jamar-navy); } .tb.closed { background: var(--green); }
    .trend-x { font-size: .66rem; color: var(--muted); margin-top: 6px; white-space: nowrap; transform: rotate(-35deg); transform-origin: top left; height: 26px; }
    .legend { display:flex; gap:16px; margin-bottom:6px; font-size:.78rem; color: var(--muted); }
    .legend i { display:inline-block; width:11px; height:11px; border-radius:3px; margin-right:5px; vertical-align:middle; }
    .table-tools { display:flex; gap:12px; align-items:center; margin-bottom:12px; flex-wrap:wrap; }
    .table-tools input { flex:1; min-width:200px; background:#fff; color: var(--text); border: 1px solid var(--border); border-radius: 8px; padding: 9px 12px; }
    .table-wrap { overflow-x: auto; border-radius: 12px; border: 1px solid var(--border); max-height: 620px; }
    table { width: 100%; border-collapse: collapse; font-size: .82rem; }
    th, td { padding: 9px 12px; text-align: left; border-bottom: 1px solid var(--border); white-space: nowrap; }
    th { background: var(--jamar-navy); color: #fff; cursor: pointer; user-select: none; position: sticky; top: 0; font-weight: 600; }
    th:hover { background: #0e1830; }
    tbody tr:nth-child(even) { background: #fafbfc; }
    tbody tr:hover { background: #fff5f5; }
    td.summary { white-space: normal; max-width: 320px; }
    .dot { display:inline-block; width:9px; height:9px; border-radius:50%; margin-right:6px; }
    .dot.new { background: var(--jamar-navy); } .dot.indeterminate { background: var(--jamar-gold); } .dot.done { background: var(--green); }
    .pill { padding:2px 8px; border-radius:6px; font-size:.74rem; background: var(--panel-2); }
    .pill.overdue { background: rgba(227,6,19,.10); color: var(--jamar-red); font-weight:700; }
    .muted { color: var(--muted); }
    footer { text-align:center; color: var(--muted); font-size:.8rem; padding: 24px; border-top: 1px solid var(--border); margin-top: 20px; }
    .empty { text-align:center; padding:24px; color: var(--muted); }
  </style>
</head>
<body>
  <header>
    <h1>{{ metrics.meta.title }}</h1>
    <div class="sub">Generado automaticamente el {{ metrics.meta.generated_at_human }} - Zona horaria: {{ metrics.meta.timezone }}</div>
  </header>
  <div class="container">
    <div class="filters">
      <div class="field"><label for="f-project">Proyecto</label><select id="f-project"><option value="">Todos</option></select></div>
      <div class="field"><label for="f-assignee">Persona asignada</label><select id="f-assignee"><option value="">Todos</option></select></div>
      <div class="field"><label for="f-reporter">Informador</label><select id="f-reporter"><option value="">Todos</option></select></div>
      <div class="field"><label for="f-activity">Actividad</label><select id="f-activity"><option value="">Todas</option></select></div>
      <div class="field"><label for="f-from">Creado desde</label><input type="date" id="f-from" /></div>
      <div class="field"><label for="f-to">Creado hasta</label><input type="date" id="f-to" /></div>
      <button id="btn-apply" class="js-only">Aplicar filtros</button>
      <button id="btn-reset" class="ghost js-only">Limpiar</button>
    </div>
    {%- set c = metrics.kpis.compliance -%}
    {%- if c >= 85 -%}{% set sem = 'green' %}{% elif c >= 60 -%}{% set sem = 'amber' %}{% else -%}{% set sem = 'red' %}{%- endif -%}
    <div class="kpis" id="kpis">
      <div class="kpi navy"><div class="label">Total tickets</div><div class="value">{{ metrics.kpis.total }}</div></div>
      <div class="kpi amber"><div class="label">Abiertos</div><div class="value">{{ metrics.kpis.open }}</div></div>
      <div class="kpi green"><div class="label">Cerrados</div><div class="value">{{ metrics.kpis.closed }}</div></div>
      <div class="kpi violet"><div class="label">En progreso</div><div class="value">{{ metrics.kpis.in_progress }}</div></div>
      <div class="kpi red"><div class="label">Vencidos (vencimiento)</div><div class="value">{{ metrics.kpis.overdue }}</div></div>
      <div class="kpi gold"><div class="label">Vencidos (estimada L4)</div><div class="value">{{ metrics.kpis.overdue_l4 }}</div></div>
      <div class="kpi {{ sem }}"><div class="label">Cumplimiento</div><div class="value">{{ metrics.kpis.compliance }}<span class="unit"> %</span></div><span class="badge {{ sem }}">{{ 'Optimo' if sem == 'green' else ('Atencion' if sem == 'amber' else 'Critico') }}</span></div>
      <div class="kpi navy"><div class="label">T. prom. resolucion</div><div class="value">{{ metrics.kpis.avg_resolution_days }}<span class="unit"> dias</span></div></div>
    </div>
    <div class="grid">
      <div class="card"><h3>Tickets por estado</h3><div class="bars" id="bars-status">{{ bars(metrics.by_status) }}</div></div>
      <div class="card"><h3>Tickets por prioridad</h3><div class="bars" id="bars-priority">{{ bars(metrics.by_priority) }}</div></div>
      <div class="card"><h3>Tickets por actividad</h3><div class="bars" id="bars-activity">{{ bars(metrics.by_activity) }}</div></div>
      <div class="card"><h3>Tickets por resolucion</h3><div class="bars" id="bars-resolution">{{ bars(metrics.by_resolution) }}</div></div>
      <div class="card"><h3>Top 10 personas asignadas</h3><div class="bars" id="bars-assignee">{{ bars(metrics.by_assignee, 10) }}</div></div>
      <div class="card"><h3>Top 10 informadores</h3><div class="bars" id="bars-reporter">{{ bars(metrics.by_reporter, 10) }}</div></div>
      <div class="card wide"><h3>Tendencia semanal (creadas vs cerradas)</h3><div class="legend"><span><i style="background:var(--jamar-navy)"></i>Creadas</span><span><i style="background:var(--green)"></i>Cerradas</span></div><div id="trend-weekly">{{ trendchart(metrics.trend_weekly) }}</div></div>
      <div class="card wide"><h3>Tendencia mensual (creadas vs cerradas)</h3><div class="legend"><span><i style="background:var(--jamar-navy)"></i>Creadas</span><span><i style="background:var(--green)"></i>Cerradas</span></div><div id="trend-monthly">{{ trendchart(metrics.trend_monthly) }}</div></div>
    </div>
    <div class="card">
      <h3>Detalle de tickets <span class="muted" id="row-count">({{ metrics.table | length }})</span></h3>
      <div class="table-tools"><input type="text" id="search" class="js-only" placeholder="Buscar..." /></div>
      <div class="table-wrap">
        <table id="table">
          <thead><tr>
            <th data-k="key">Clave</th><th data-k="summary">Resumen</th><th data-k="activity">Actividad</th>
            <th data-k="assignee">Persona asignada</th><th data-k="reporter">Informador</th><th data-k="priority">Prioridad</th>
            <th data-k="status">Estado</th><th data-k="resolution">Resolucion</th><th data-k="created">Creada</th>
            <th data-k="updated">Actualizada</th><th data-k="duedate">Vencimiento</th><th data-k="start">Fecha inicio</th><th data-k="l4">Estimada L4</th>
          </tr></thead>
          <tbody id="tbody">
            {%- for r in metrics.table[:200] -%}
            <tr>
              <td>{{ r.key }}</td><td class="summary">{{ r.summary }}</td><td>{{ r.activity }}</td>
              <td>{{ r.assignee }}</td><td>{{ r.reporter }}</td><td>{{ r.priority }}</td>
              <td><span class="dot {{ r.status_category }}"></span>{{ r.status }}</td><td>{{ r.resolution }}</td>
              <td>{{ r.created }}</td><td>{{ r.updated }}</td>
              <td>{% if r.duedate %}<span class="pill {{ 'overdue' if r.overdue else '' }}">{{ r.duedate }}</span>{% else %}<span class="muted">-</span>{% endif %}</td>
              <td>{{ r.start or '-' }}</td>
              <td>{% if r.l4 %}<span class="pill {{ 'overdue' if r.overdue_l4 else '' }}">{{ r.l4 }}</span>{% else %}<span class="muted">-</span>{% endif %}</td>
            </tr>
            {%- endfor -%}
          </tbody>
        </table>
      </div>
    </div>
    <footer>Dashboard generado con Python - Jinja2 - GitHub Pages - Paleta Muebles Jamar. Actualizado: {{ metrics.meta.generated_at_human }}.</footer>
  </div>
  <script id="data" type="application/json">{{ metrics_json | safe }}</script>
  <script>
  (function () {
    "use strict";
    var dataEl = document.getElementById("data");
    if (!dataEl) return;
    var DATA = JSON.parse(dataEl.textContent);
    var ALL = DATA.table || [];
    var PALETTE = ['#E30613','#14213D','#F4A81D','#2E933C','#7A5AD8','#0EA5A4','#EF7C1B','#3B82F6','#D6336C','#8D6E63'];
    var el = function (id) { return document.getElementById(id); };
    Array.prototype.forEach.call(document.querySelectorAll('.js-only'), function (n) { n.style.display = ''; });
    function fillSelect(id, values) {
      var sel = el(id); if (!sel) return;
      values.forEach(function (v) { var o = document.createElement('option'); o.value = v; o.textContent = v; sel.appendChild(o); });
    }
    fillSelect('f-project', DATA.filters.projects || []);
    fillSelect('f-assignee', DATA.filters.assignees || []);
    fillSelect('f-reporter', DATA.filters.reporters || []);
    fillSelect('f-activity', DATA.filters.activities || []);
    function escapeHtml(s){ return (s||'').replace(/[&<>"']/g, function(ch){ return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[ch]; }); }
    function applyFilters() {
      var proj = el('f-project').value, asg = el('f-assignee').value, rep = el('f-reporter').value,
          act = el('f-activity').value, from = el('f-from').value, to = el('f-to').value,
          q = (el('search').value || '').toLowerCase();
      return ALL.filter(function (r) {
        if (proj && r.project !== proj) return false;
        if (asg && r.assignee !== asg) return false;
        if (rep && r.reporter !== rep) return false;
        if (act && r.activity !== act) return false;
        if (from && (r.created || '') < from) return false;
        if (to && (r.created || '') > to) return false;
        if (q) {
          var hay = (r.key+' '+r.summary+' '+r.status+' '+r.priority+' '+r.assignee+' '+r.reporter+' '+r.project+' '+r.activity+' '+r.resolution).toLowerCase();
          if (hay.indexOf(q) === -1) return false;
        }
        return true;
      });
    }
    function countBy(rows, key) {
      var m = {};
      rows.forEach(function (r) { var v = r[key] || 'N/D'; m[v] = (m[v]||0)+1; });
      return Object.keys(m).map(function (k){ return [k, m[k]]; }).sort(function (a,b){ return b[1]-a[1]; });
    }
    function renderBars(id, entries, limit) {
      var node = el(id); if (!node) return;
      var arr = limit ? entries.slice(0, limit) : entries;
      var mx = arr.reduce(function (a,e){ return Math.max(a, e[1]); }, 0) || 1;
      node.innerHTML = arr.map(function (e, i) {
        var w = (e[1]/mx*100).toFixed(1);
        return '<div class="bar-row"><span class="bar-label" title="'+escapeHtml(e[0])+'">'+escapeHtml(e[0])+'</span><span class="bar-track"><span class="bar-fill" style="width:'+w+'%;background:'+PALETTE[i%PALETTE.length]+'"></span></span><span class="bar-val">'+e[1]+'</span></div>';
      }).join('') || '<div class="empty">Sin datos</div>';
    }
    function period(dateStr, mode) {
      var d = new Date(dateStr);
      if (mode === 'month') return d.getUTCFullYear()+'-'+String(d.getUTCMonth()+1).padStart(2,'0');
      var onejan = new Date(Date.UTC(d.getUTCFullYear(),0,1));
      var week = Math.ceil((((d - onejan)/86400000) + onejan.getUTCDay()+1)/7);
      return d.getUTCFullYear()+'-S'+String(week).padStart(2,'0');
    }
    function trendData(rows, mode) {
      var cc = {}, zc = {};
      rows.forEach(function (r) {
        if (r.created) { var p = period(r.created, mode); cc[p] = (cc[p]||0)+1; }
        if (r.resolved){ var q = period(r.resolved, mode); zc[q] = (zc[q]||0)+1; }
      });
      var labels = Object.keys(cc).concat(Object.keys(zc)).filter(function (v,i,a){ return a.indexOf(v)===i; }).sort().slice(-12);
      return { labels: labels, created: labels.map(function (p){ return cc[p]||0; }), closed: labels.map(function (p){ return zc[p]||0; }) };
    }
    function renderTrend(id, t) {
      var node = el(id); if (!node) return;
      var mx = Math.max.apply(null, t.created.concat(t.closed).concat([1]));
      node.innerHTML = '<div class="trend">' + t.labels.map(function (lab, i) {
        var hc = (t.created[i]/mx*100).toFixed(1), hz = (t.closed[i]/mx*100).toFixed(1);
        return '<div class="trend-col"><div class="trend-bars"><span class="tb created" style="height:'+hc+'%" title="Creadas: '+t.created[i]+'"></span><span class="tb closed" style="height:'+hz+'%" title="Cerradas: '+t.closed[i]+'"></span></div><span class="trend-x">'+lab+'</span></div>';
      }).join('') + '</div>';
    }
    function renderKpis(rows) {
      var total = rows.length;
      var closed = rows.filter(function (r){ return r.status_category==='done'; }).length;
      var inProg = rows.filter(function (r){ return r.status_category==='indeterminate'; }).length;
      var open = total - closed;
      var overdue = rows.filter(function (r){ return r.overdue; }).length;
      var overdueL4 = rows.filter(function (r){ return r.overdue_l4; }).length;
      var compliance = total ? Math.round((closed/total)*1000)/10 : 0;
      var days = [];
      rows.forEach(function (r){ if (r.resolved && r.created){ var d=(new Date(r.resolved)-new Date(r.created))/86400000; if (d>=0) days.push(d); } });
      var avg = days.length ? Math.round((days.reduce(function(a,b){return a+b;},0)/days.length)*10)/10 : 0;
      var sem = compliance>=85?'green':(compliance>=60?'amber':'red');
      var semTxt = sem==='green'?'Optimo':(sem==='amber'?'Atencion':'Critico');
      var cards = [
        ['navy','Total tickets',total,''],['amber','Abiertos',open,''],['green','Cerrados',closed,''],
        ['violet','En progreso',inProg,''],['red','Vencidos (vencimiento)',overdue,''],['gold','Vencidos (estimada L4)',overdueL4,''],
        [sem,'Cumplimiento',compliance,' %','<span class="badge '+sem+'">'+semTxt+'</span>'],['navy','T. prom. resolucion',avg,' dias']
      ];
      el('kpis').innerHTML = cards.map(function (cc) {
        return '<div class="kpi '+cc[0]+'"><div class="label">'+cc[1]+'</div><div class="value">'+cc[2]+'<span class="unit">'+cc[3]+'</span></div>'+(cc[4]||'')+'</div>';
      }).join('');
    }
    var sortKey = 'created', sortDir = -1;
    function renderTable(rows) {
      var tbody = el('tbody'); el('row-count').textContent = '('+rows.length+')';
      if (!rows.length) { tbody.innerHTML = '<tr><td colspan="13" class="empty">Sin resultados.</td></tr>'; return; }
      var sorted = rows.slice().sort(function (a,b){ var va=a[sortKey]||'', vb=b[sortKey]||''; return va<vb?-sortDir:va>vb?sortDir:0; });
      var dash = '<span class="muted">-</span>';
      tbody.innerHTML = sorted.slice(0, 1000).map(function (r) {
        return '<tr><td>'+r.key+'</td><td class="summary">'+escapeHtml(r.summary)+'</td><td>'+escapeHtml(r.activity)+'</td><td>'+escapeHtml(r.assignee)+'</td><td>'+escapeHtml(r.reporter)+'</td><td>'+r.priority+'</td><td><span class="dot '+r.status_category+'"></span>'+escapeHtml(r.status)+'</td><td>'+escapeHtml(r.resolution)+'</td><td>'+(r.created||dash)+'</td><td>'+(r.updated||dash)+'</td><td>'+(r.duedate?'<span class="pill '+(r.overdue?'overdue':'')+'">'+r.duedate+'</span>':dash)+'</td><td>'+(r.start||dash)+'</td><td>'+(r.l4?'<span class="pill '+(r.overdue_l4?'overdue':'')+'">'+r.l4+'</span>':dash)+'</td></tr>';
      }).join('');
    }
    Array.prototype.forEach.call(document.querySelectorAll('#table th'), function (th) {
      th.addEventListener('click', function () {
        var k = th.dataset.k;
        if (sortKey === k) sortDir *= -1; else { sortKey = k; sortDir = 1; }
        render();
      });
    });
    function render() {
      var rows = applyFilters();
      renderKpis(rows);
      renderBars('bars-status', countBy(rows,'status'));
      renderBars('bars-priority', countBy(rows,'priority'));
      renderBars('bars-activity', countBy(rows,'activity'));
      renderBars('bars-resolution', countBy(rows,'resolution'));
      renderBars('bars-assignee', countBy(rows,'assignee'), 10);
      renderBars('bars-reporter', countBy(rows,'reporter'), 10);
      renderTrend('trend-weekly', trendData(rows,'week'));
      renderTrend('trend-monthly', trendData(rows,'month'));
      renderTable(rows);
    }
    el('btn-apply').addEventListener('click', render);
    el('search').addEventListener('input', render);
    el('btn-reset').addEventListener('click', function () {
      el('f-project').value=''; el('f-assignee').value=''; el('f-reporter').value='';
      el('f-activity').value=''; el('f-from').value=''; el('f-to').value=''; el('search').value='';
      render();
    });
    render();
  })();
  </script>
</body>
</html>
