# =====================================================================
#  CONFIGURACIÓN DE CONEXIÓN A JIRA CLOUD
#  Copia este archivo como  .env  y rellena tus valores reales.
#  NUNCA subas el .env al repositorio (está en .gitignore).
# =====================================================================

# URL base de tu instancia Jira Cloud (sin barra final)
JIRA_BASE_URL=https://tu-empresa.atlassian.net

# Email de la cuenta Atlassian con la que generaste el token
JIRA_EMAIL=tu-correo@tu-empresa.com

# API Token de Atlassian (NO es tu contraseña).
# Se crea en: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=tu_api_token_aqui

# Claves de proyecto a consultar. Una o varias separadas por coma.
# Ej: OPS   |   OPS,SOPORTE,DEV
JIRA_PROJECT_KEYS=OPS,SOPORTE

# (Opcional) Días hacia atrás para la consulta. Por defecto 180.
JIRA_LOOKBACK_DAYS=180

# (Opcional) Nº máximo de issues por página (máx. 100 en Jira Cloud).
JIRA_PAGE_SIZE=100

# (Opcional) Nombre del campo SLA / fecha objetivo (due date por defecto).
# Si usas un campo personalizado para vencimiento, pon su id: customfield_10030
JIRA_DUEDATE_FIELD=duedate

# ── Campos personalizados (se resuelven AUTOMÁTICAMENTE por su nombre visible) ──
# Escribe el nombre EXACTO tal como aparece en tu Jira. El cliente busca su
# customfield_XXXXX solo. Déjalos vacíos si no aplican.
JIRA_FIELD_ACTIVITY=Actividad
JIRA_FIELD_START=Fecha inicio
JIRA_FIELD_L4=Fecha estimada L4

# Criterio del KPI principal de "vencidos": "duedate" o "l4".
JIRA_OVERDUE_BASIS=duedate

# (Opcional) Nombre de la empresa/área para mostrar en el encabezado.
DASHBOARD_TITLE=Dashboard Ejecutivo de Gestión - Jira

# (Opcional) Zona horaria para fechas mostradas (formato IANA).
DASHBOARD_TIMEZONE=America/Bogota
